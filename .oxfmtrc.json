{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "endOfLine": "lf",
  "singleQuote": true,
  "trailingComma": "all",
  "sortImports": {
    "groups": [
      ["builtin", "external", "unknown"],
      { "newlinesBetween": true },
      ["internal", "parent", "sibling", "index"]
    ]
  }
}
